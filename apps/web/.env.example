# Server-side target of the /api-proxy/* rewrite (next.config.mjs). The browser
# only ever calls the relative /api-proxy path — same-origin, so the HttpOnly
# session cookie flows even in Safari / the LINE in-app browser. Set this in
# Vercel to the deployed API origin, e.g. https://<api-service>.up.railway.app
# (no trailing slash). NOT a NEXT_PUBLIC_ var — it must stay server-side.
API_PROXY_TARGET=http://localhost:3001

NEXT_PUBLIC_LINE_LOGIN_CHANNEL_ID=xxxxxxxxxx
