# ── App ──────────────────────────────────────────
NODE_ENV=development
PORT=3001
# The BullMQ worker exposes /health on its own port (kept off the API's PORT so
# both run on one host in local dev). Point the Railway worker healthcheck here.
WORKER_HEALTH_PORT=3002
APP_URL=http://localhost:3001
WEB_URL=http://localhost:3000

# ── LINE (Messaging API channel) ─────────────────
LINE_CHANNEL_ID=xxxxxxxxxx
LINE_CHANNEL_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LINE_CHANNEL_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── LINE Login channel (Web Dashboard) ───────────
LINE_LOGIN_CHANNEL_ID=xxxxxxxxxx
LINE_LOGIN_CHANNEL_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── ระบบตามงาน (Task Manager) ────────────────────
# LIFF app id — now hosted by a LINE MINI App channel (migrated off the LINE
# Login channel). Endpoint URL = <WEB_URL>/liff/tasks. Format {channelId}-{suffix}.
# Optional: unset → task links in LINE messages fall back to plain WEB_URL links.
LINE_LIFF_ID=2010750761-xxxxxxxx
# Channel id that issues the MINI App id token (its `aud`), verified at
# /auth/liff. Leave unset to derive it from LINE_LIFF_ID's numeric prefix
# (2010750761). Set explicitly only if the LIFF id and its channel ever diverge.
# LINE_LIFF_CHANNEL_ID=2010750761

# ── Supabase ─────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...    # server-side only, ไม่ expose FE

# ── Cloudflare R2 ─────────────────────────────────
R2_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxx
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
R2_BUCKET_NAME=nookeb-files

# ── Redis (Upstash) ───────────────────────────────
# BullMQ ต้องใช้ Redis TCP connection (ใช้ rediss:// URL จากหน้า Upstash)
REDIS_URL=rediss://default:xxxx@xxxx.upstash.io:6379

# ── Security ─────────────────────────────────────
JWT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  # 32+ chars random
DOWNLOAD_TOKEN_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  # optional, 32+ chars — signs one-time ?dl_token= download tokens (falls back to a JWT_SECRET-derived key)

# ── Quota / Admin (Phase 4) ──────────────────────
DEFAULT_STORAGE_LIMIT=1073741824           # free-tier quota in bytes (1 GB — raised via referrals, migration 010)
REFERRAL_BONUS_BYTES=536870912             # one-time bonus for redeeming a referral code (0.5 GB)
ADMIN_LINE_USER_IDS=Uxxxxxxxx,Uyyyyyyyy    # LINE user ids with admin access (comma-separated)
PURGE_RETENTION_DAYS=5                      # purge R2 objects of soft-deleted files after N days (default 5; free-tier trash window)
TRASH_RETENTION_DAYS_PRO=30                 # trash retention for pro/team-plan users (default 30)

# ── Upload limits & rate limiting ────────────────
MAX_FILE_SIZE_BYTES=1073741824              # hard cap per file (1 GB) — larger files are rejected before download
RATE_LIMIT_FILES_PER_HOUR=50                # max files per user per rolling hour
RATE_LIMIT_BYTES_PER_HOUR=5368709120        # max bytes per user per rolling hour (5 GB)

# ── VirusTotal malware scanning (optional) ───────
# Get a free key: sign up at https://www.virustotal.com → profile → API Key.
# Free tier: 4 requests/min, 32 MB max upload. Scanning is DISABLED until the
# key is set; files over the scan size cap are stored with scan_status=skipped_size.
# Requires migration 004 (files.scan_status column).
# Set to 'true' to enable VirusTotal scanning (adds ~5-60s per file)
ENABLE_VIRUS_SCAN=false
VIRUSTOTAL_API_KEY=
VIRUSTOTAL_MAX_SCAN_SIZE_BYTES=33554432     # VT free-tier upload cap (32 MB)

# ── Scan-enhance pipeline (รวมรูป → PDF) ─────────
# Edge detection + perspective correction + color enhancement on scan pages.
# Requires migration 019 (scan_sessions.scan_mode).
SCAN_ENHANCE_ENABLED=true                   # 'false' disables (raw images passed to PDF as-is)
SCAN_OCR_ENABLED=false                      # searchable-text PDF layer — reserved, keep false
SCAN_DEFAULT_MODE=bw                        # 'bw' (text docs) | 'color' (docs with images)

# ── Mistral OCR / convert-to-Word (optional) ─────
# Powers "หนูเก็บแปลงไฟล์" (image/PDF → editable .docx). The command replies
# "not available" until the key is set. Get a key: https://console.mistral.ai
# Pin the model id for cost control — 'mistral-ocr-latest' tracks the newest
# (pricier) release; OCR 3 is ~half the per-page price of OCR 4.
MISTRAL_API_KEY=
MISTRAL_OCR_MODEL=mistral-ocr-latest
DOCX_CONVERT_MAX_SOURCE_BYTES=10485760      # convert-to-Word source cap (10 MB)

# ── ระบบรวมไฟล์ PDF (PDF Merge, migration 044) ─
# Sources AND the merged output are buffered in worker memory — worst case is
# roughly MAX_SOURCE_BYTES × MAX_SOURCES. Raise both together, deliberately.
PDF_MERGE_MAX_SOURCE_BYTES=20971520          # per-source PDF cap (20 MB)
PDF_MERGE_MAX_SOURCES=20                     # max PDFs in one merge

# ── ไดอารี่ 365 วัน (My Diary, migration 028) ─
DIARY_MAX_IMAGE_BYTES=10485760              # per-photo cap (10 MB, jpg/png/webp only)

# ── ห้องนิรภัย (Vault, migration 031) ─
# PIN-protected encrypted file store. Routes reply 503 until the key is set.
# Generate: openssl rand -hex 32. Set on BOTH Railway services (API + worker —
# the worker's daily purge needs R2 access; the key itself is only used by the
# API, but keeping env sets identical avoids per-service drift).
# WARNING: rotating or losing this key makes every existing vault file
# permanently unreadable — back it up like a database.
VAULT_MASTER_KEY=6a7c806cf23c58815e46410cddfef3a4eaa0683d95a8387594f6924691444e0c
VAULT_MAX_FILE_SIZE_MB=100                  # per-file vault upload cap
VAULT_PURGE_RETENTION_DAYS=30               # hard-purge soft-deleted vault files after N days

# ── Storage warning thresholds (% of user quota) ─
# Space owner gets a LINE push at each threshold; re-armed when usage drops <70%.
# Requires migration 004 (space_storage_alerts table).
STORAGE_WARN_THRESHOLD_LOW=80
STORAGE_WARN_THRESHOLD_HIGH=95
