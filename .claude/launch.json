{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--workspace=@nookeb/web"],
      "port": 3000
    },
    {
      "name": "web-autoport",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["exec", "--workspace=@nookeb/web", "--", "next", "dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "api",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:api", "--workspace=@nookeb/api"],
      "port": 3001
    }
  ]
}
